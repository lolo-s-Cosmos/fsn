{
  "name": "fate-sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Fate sandbox — pi coding agent experimental interactive narrative card",
  "keywords": [
    "interactive-fiction",
    "pi-card",
    "pi-package"
  ],
  "license": "GPL-3.0-or-later",
  "files": [
    "agents/",
    "data/",
    "engine/",
    "extensions/",
    "skills/",
    "tools/",
    ".pi/agents/",
    ".pi/settings.json",
    "extension.ts",
    "start.sh",
    "scripts/package-release.sh",
    "README.md",
    "CHANGELOG.md",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.json",
    ".oxlintrc.json",
    ".oxfmtrc.json",
    "LICENSE",
    "start.ps1"
  ],
  "type": "module",
  "scripts": {
    "start": "./start.sh",
    "deps:install": "pnpm install --prod",
    "pack:release": "bash scripts/package-release.sh",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "node --test 'engine/**/*.test.ts' 'tools/**/*.test.ts' 'tests/**/*.test.ts' 'extensions/**/*.test.ts'",
    "audit:session": "node scripts/audit-session.ts",
    "deadcode": "pnpx knip --include files"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "^0.77.0",
    "@js-temporal/polyfill": "^0.5.1",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "jiti": "^2.7.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2"
}
