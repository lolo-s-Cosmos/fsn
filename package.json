{
  "name": "fate-sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Fate/strange Fake Snowfield sandbox — pi coding agent interactive card",
  "keywords": [
    "interactive-fiction",
    "pi-card",
    "pi-package"
  ],
  "license": "GPL-3.0-or-later",
  "files": [
    "agents/",
    "data/",
    "docs/",
    "engine/",
    "extensions/",
    "skills/",
    "tools/",
    ".pi/agents/",
    ".pi/settings.json",
    "extension.ts",
    "start.sh",
    "scripts/package-release.sh",
    "README.md",
    "CHANGELOG.md",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "tsconfig.json",
    ".oxlintrc.json",
    ".oxfmtrc.json",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "start": "./start.sh",
    "deps:install": "pnpm install --prod",
    "pack:release": "bash scripts/package-release.sh",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "pnpx tsx --test 'engine/**/*.test.ts' 'tools/**/*.test.ts' 'tests/**/*.test.ts'"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "^0.77.0",
    "@js-temporal/polyfill": "^0.5.1",
    "rfc6902": "^5.2.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@types/node": "^25.9.1",
    "jiti": "^2.7.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typebox": "^1.1.38",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
